# name: test/sql/main/writing/ctas/ctas_type_coverage.test
# description: CTAS with a variety of supported Delta column types
# group: [ctas]

require parquet

require delta

require notwindows

statement ok
ATTACH '__TEST_DIR__/ctas/types' AS t (TYPE delta, allow_create true);

statement ok
CREATE TABLE t.t AS
SELECT
    true                            AS c_bool,
    CAST(1 AS TINYINT)             AS c_byte,
    CAST(2 AS SMALLINT)            AS c_short,
    CAST(3 AS INTEGER)             AS c_int,
    CAST(4 AS BIGINT)              AS c_long,
    CAST(1.5 AS FLOAT)             AS c_float,
    CAST(2.5 AS DOUBLE)            AS c_double,
    'hello'                        AS c_string,
    CAST('2024-01-01' AS DATE)     AS c_date,
    CAST(1.23 AS DECIMAL(10,3))    AS c_decimal;

query I
SELECT count(*) FROM t;
----
1

query I
SELECT c_int FROM t;
----
3

statement ok
DETACH t;
